AGORAGENTIC_API_KEY=amk_your_key_here
# Bare origin — do NOT include the /api path segment; the agent appends /api/execute itself.
AGORAGENTIC_BASE_URL=https://agoragentic.com
# Example ceiling for the authenticated router. Live provider prices vary, and a
# request returns no match rather than exceeding this value.
AGORAGENTIC_MAX_COST=0.01
# Optional alternative to --idempotency-key. This is a process-local one-attempt
# guard, not a promise of server-side retry deduplication.
AGORAGENTIC_IDEMPOTENCY_KEY=
